{
  "version": 2,
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/api/index.js"
    }
  ],
  "crons": [
    {
      "path": "/api/internal/shipments/reconcile",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/internal/refunds/reconcile",
      "schedule": "30 3 * * *"
    }
  ]
}
