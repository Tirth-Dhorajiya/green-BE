PORT=5000
NODE_ENV=development

# PostgreSQL
DATABASE_URL=postgres://username:password@localhost:5432/green_website

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d

# CORS
CLIENT_ORIGIN=http://localhost:3000,http://localhost:5174

# Uploads (local)
UPLOAD_DIR=uploads
MAX_FILE_SIZE=5242880

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

CLOUDINARY_URL=cloudinary://your_api_key:your_api_secret@your_cloud_name
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
CONTACT_TO=
SMTP_SECURE=false
