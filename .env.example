PORT=5000
NODE_ENV=development

# PostgreSQL
DATABASE_URL=postgres://username:password@localhost:5432/green_website

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d

# CORS
CLIENT_ORIGIN=http://localhost:3000,http://localhost:5174

# Uploads (local)
UPLOAD_DIR=uploads
MAX_FILE_SIZE=5242880

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

CLOUDINARY_URL=cloudinary://your_api_key:your_api_secret@your_cloud_name

# Razorpay
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_CURRENCY=INR

# Delhivery B2C (use staging until certification is complete)
DELHIVERY_ENV=staging
DELHIVERY_API_TOKEN=your_delhivery_test_token
DELHIVERY_CLIENT_NAME=your_case_sensitive_client_name
DELHIVERY_PICKUP_LOCATION=your_case_sensitive_warehouse_name
# Optional account/tax defaults when required by your Delhivery agreement
DELHIVERY_SELLER_GST_TIN=
DELHIVERY_DEFAULT_HSN_CODE=
DELHIVERY_WEBHOOK_SECRET=replace_with_a_long_random_secret
CRON_SECRET=replace_with_a_different_long_random_secret

# Email / contact
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
CONTACT_TO=
SMTP_SECURE=false
