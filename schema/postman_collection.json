{
  "info": {
    "name": "Green Store API",
    "description": "Plant, Seeds & Gardening Tools eCommerce Backend",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "BASE_URL", "value": "http://localhost:5000" },
    { "key": "TOKEN", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "url": "{{BASE_URL}}/api/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john@example.com\",\n  \"password\": \"secret123\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "url": "{{BASE_URL}}/api/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@example.com\",\n  \"password\": \"secret123\"\n}"
            }
          }
        },
        {
          "name": "Get Me",
          "request": {
            "method": "GET",
            "url": "{{BASE_URL}}/api/auth/me",
            "header": [{ "key": "Authorization", "value": "Bearer {{TOKEN}}" }]
          }
        }
      ]
    },
    {
      "name": "Products",
      "item": [
        {
          "name": "Get All Products",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{BASE_URL}}/api/products?page=1&limit=10&category=plants&sortBy=price&order=asc",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "products"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" },
                { "key": "category", "value": "plants" },
                { "key": "sortBy", "value": "price" },
                { "key": "order", "value": "asc" }
              ]
            }
          }
        },
        {
          "name": "Get Single Product",
          "request": {
            "method": "GET",
            "url": "{{BASE_URL}}/api/products/1"
          }
        },
        {
          "name": "Add Product (Admin)",
          "request": {
            "method": "POST",
            "url": "{{BASE_URL}}/api/products",
            "header": [{ "key": "Authorization", "value": "Bearer {{TOKEN}}" }],
            "body": {
              "mode": "form-data",
              "formdata": [
                { "key": "name", "value": "Monstera Deliciosa", "type": "text" },
                { "key": "description", "value": "Tropical plant with beautiful leaves", "type": "text" },
                { "key": "price", "value": "29.99", "type": "text" },
                { "key": "category", "value": "plants", "type": "text" },
                { "key": "stock", "value": "50", "type": "text" },
                { "key": "image", "type": "file", "src": "" }
              ]
            }
          }
        },
        {
          "name": "Update Product (Admin)",
          "request": {
            "method": "PUT",
            "url": "{{BASE_URL}}/api/products/1",
            "header": [
              { "key": "Authorization", "value": "Bearer {{TOKEN}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"price\": 24.99,\n  \"stock\": 100\n}"
            }
          }
        },
        {
          "name": "Delete Product (Admin)",
          "request": {
            "method": "DELETE",
            "url": "{{BASE_URL}}/api/products/1",
            "header": [{ "key": "Authorization", "value": "Bearer {{TOKEN}}" }]
          }
        }
      ]
    },
    {
      "name": "Cart",
      "item": [
        {
          "name": "Get Cart",
          "request": {
            "method": "GET",
            "url": "{{BASE_URL}}/api/cart",
            "header": [{ "key": "Authorization", "value": "Bearer {{TOKEN}}" }]
          }
        },
        {
          "name": "Add to Cart",
          "request": {
            "method": "POST",
            "url": "{{BASE_URL}}/api/cart",
            "header": [
              { "key": "Authorization", "value": "Bearer {{TOKEN}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"product_id\": 1,\n  \"quantity\": 2\n}"
            }
          }
        },
        {
          "name": "Update Cart Item",
          "request": {
            "method": "PUT",
            "url": "{{BASE_URL}}/api/cart/1",
            "header": [
              { "key": "Authorization", "value": "Bearer {{TOKEN}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"quantity\": 5\n}"
            }
          }
        },
        {
          "name": "Remove Cart Item",
          "request": {
            "method": "DELETE",
            "url": "{{BASE_URL}}/api/cart/1",
            "header": [{ "key": "Authorization", "value": "Bearer {{TOKEN}}" }]
          }
        }
      ]
    },
    {
      "name": "Orders",
      "item": [
        {
          "name": "Create Order",
          "request": {
            "method": "POST",
            "url": "{{BASE_URL}}/api/orders",
            "header": [{ "key": "Authorization", "value": "Bearer {{TOKEN}}" }]
          }
        },
        {
          "name": "Get My Orders",
          "request": {
            "method": "GET",
            "url": "{{BASE_URL}}/api/orders/my",
            "header": [{ "key": "Authorization", "value": "Bearer {{TOKEN}}" }]
          }
        },
        {
          "name": "Get All Orders (Admin)",
          "request": {
            "method": "GET",
            "url": "{{BASE_URL}}/api/orders?page=1&limit=20&status=pending",
            "header": [{ "key": "Authorization", "value": "Bearer {{TOKEN}}" }]
          }
        },
        {
          "name": "Update Order Status (Admin)",
          "request": {
            "method": "PUT",
            "url": "{{BASE_URL}}/api/orders/1/status",
            "header": [
              { "key": "Authorization", "value": "Bearer {{TOKEN}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"shipped\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "Dashboard Stats",
          "request": {
            "method": "GET",
            "url": "{{BASE_URL}}/api/admin/stats",
            "header": [{ "key": "Authorization", "value": "Bearer {{TOKEN}}" }]
          }
        }
      ]
    }
  ]
}
